#!/usr/bin/env bash
#
# Pre-commit hook — runs the two fast checks CI enforces, so a push
# doesn't fail on something we could have caught locally in seconds.
#
# Enable once per clone:
#   git config core.hooksPath .githooks
# or:
#   ./scripts/install-hooks.sh
#
# Skip for a single WIP commit (use sparingly):
#   git commit --no-verify
#
# NOTE: we deliberately don't run `go test ./... -race` here — CI does
# that and it takes long enough to be a friction point for small
# commits. golangci-lint + govulncheck are also CI-only (golangci-lint
# needs a pinned binary install; govulncheck needs `go install` each
# time). gofmt + vet are the cheap ones worth gating every commit.

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "[pre-commit] gofmt -l -s ."
bad=$(gofmt -l -s .)
if [ -n "$bad" ]; then
    echo
    echo "[pre-commit] gofmt -s would reformat these files:"
    echo "$bad"
    echo "[pre-commit] Fix with: gofmt -w -s ."
    exit 1
fi

echo "[pre-commit] go vet ./..."
go vet ./...

echo "[pre-commit] OK"
